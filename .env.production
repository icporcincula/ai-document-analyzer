# Production Environment Configuration
# Copy this file to .env and update with your production values

# Application Environment
ENVIRONMENT=production
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE="AI Document Analyzer - Production"
API_VERSION="1.0.0"

# Security Configuration
SECRET_KEY=your-super-secret-production-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Redis Configuration (Celery Broker & Result Backend)
REDIS_PASSWORD=your-redis-password-here
CELERY_BROKER_URL=redis://:your-redis-password-here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your-redis-password-here@redis:6379/0

# Presidio Configuration
PRESIDIO_ANALYZER_API_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_API_URL=http://presidio-anonymizer:3001
PRESIDIO_TIMEOUT=30

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TIMEOUT=60

# File Upload Configuration
MAX_FILE_SIZE=50000000  # 50MB
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,docx,doc,jpg,jpeg,png,tiff,bmp

# Webhook Configuration
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5
WEBHOOK_RETRY_BACKOFF=2.0
WEBHOOK_SECRET_KEY=your-webhook-secret-key-here
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WEBHOOK_SIGNATURE_ALGORITHM=sha256
WEBHOOK_RATE_LIMIT=100
WEBHOOK_BURST_LIMIT=10

# Database Configuration (if using database)
DATABASE_URL=postgresql://user:password@db:5432/ai_document_analyzer
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/production.log

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=8001
HEALTH_CHECK_INTERVAL=30

# Flower Configuration (Task Monitoring)
FLOWER_URL=http://localhost:5555
FLOWER_BASIC_AUTH=admin:your-flower-password-here

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
ENABLE_SSL=true

# CORS Configuration
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key

# Performance Configuration
WORKER_CONCURRENCY=4
WORKER_MAX_TASKS_PER_CHILD=100
WORKER_MAX_MEMORY_PER_CHILD=300000  # 300MB
TASK_SOFT_TIME_LIMIT=300  # 5 minutes
TASK_TIME_LIMIT=600      # 10 minutes

# Batch Processing Configuration
MAX_BATCH_SIZE=1000
MAX_FILE_SIZE_PER_BATCH=50000000  # 50MB
BATCH_CHUNK_SIZE=100

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTIONS=ConnectionError,TimeoutError

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=10

# External Services
ENABLE_PRESIDIO=true
ENABLE_OPENAI=true
ENABLE_REDIS=true
ENABLE_CELERY=true

# Email Configuration (for alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=admin@yourdomain.com

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Monitoring and Alerting
ENABLE_ALERTS=true
ALERT_THRESHOLD_SUCCESS_RATE=80
ALERT_THRESHOLD_RESPONSE_TIME=5000  # 5 seconds
ALERT_THRESHOLD_ERROR_RATE=10

# Development/Debug (Set to false in production)
ENABLE_DEBUG_ROUTES=false
ENABLE_TEST_ENDPOINTS=false
VERBOSE_LOGGING=false